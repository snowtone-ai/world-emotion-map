{
  "name": "world-emotion-map",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "tsx --env-file .env.local scripts/seed.ts",
    "fetch-gdelt": "tsx --env-file .env.local scripts/fetch-gdelt.ts",
    "aggregate": "tsx --env-file .env.local scripts/aggregate.ts",
    "detect-anomaly": "tsx --env-file .env.local scripts/detect-anomaly.ts",
    "pipeline": "tsx --env-file .env.local scripts/fetch-gdelt.ts | tsx --env-file .env.local scripts/aggregate.ts",
    "seed-emotions": "tsx --env-file .env.local scripts/seed-emotions.ts",
    "post-to-x": "tsx --env-file .env.local scripts/post-to-x.ts",
    "post-to-x:scheduled": "tsx --env-file .env.local scripts/post-to-x.ts --mode scheduled",
    "post-to-x:anomaly": "tsx --env-file .env.local scripts/post-to-x.ts --mode anomaly",
    "generate-map-image": "tsx --env-file .env.local scripts/generate-map-image.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@google-cloud/bigquery": "^8.1.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "adm-zip": "^0.5.17",
    "js-yaml": "^4.1.0",
    "twitter-api-v2": "^1.29.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "mapbox-gl": "^3.21.0",
    "next": "16.2.3",
    "next-intl": "^4.9.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/adm-zip": "^0.5.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
